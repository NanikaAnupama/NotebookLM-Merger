# ─── Microsoft / OneDrive Credentials ───
# 1. Go to Azure Portal → App registrations → your app
# 2. Copy the Application (client) ID
# 3. Generate a new OneDrive sharing link for the target folder
# 4. Copy the Authority URL for your tenant
# 5. Replace the placeholder values below
# 6. On Streamlit Cloud: paste these into Settings → Secrets

MS_CLIENT_ID = "your-azure-client-id-here"
ONEDRIVE_FOLDER_URL = "https://your-sharepoint-site.sharepoint.com/..."
MS_AUTHORITY = "https://login.microsoftonline.com/your-tenant.onmicrosoft.com"

CANVA_CLIENT_ID = "your_canva_client_id_here"
CANVA_CLIENT_SECRET = "your_canva_client_secret_here"

# For local development:
# CANVA_REDIRECT_URI = "http://127.0.0.1:8501/"
# For Streamlit Cloud (use your actual app URL):
# CANVA_REDIRECT_URI = "https://yourapp.streamlit.app/"
